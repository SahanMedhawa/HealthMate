{
    "compilerOptions": {
        "module": "nodenext",
        "target": "esnext",
        "types": [
            "node"
        ],
        "strict": true,
        "sourceMap": true,
        "declaration": true,
        "declarationMap": true,
        "skipLibCheck": true,
        "isolatedModules": true,
        "moduleDetection": "force",
        "outDir": "./dist",
        "rootDir": "./src"
    }
}